# Server
PORT=18791
NODE_ENV=production
LOG_LEVEL=info

# OpenClaw gateway
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TIMEOUT_MS=600000

# Default execution mode when client doesn't specify X-Proxy-Mode
# Values: sync | async
PROXY_DEFAULT_MODE=sync

# Async job processing
JOB_MAX_ATTEMPTS=3
JOB_RETRY_DELAY_MS=2000
JOB_RESULT_TTL_MS=3600000
JOB_CLEANUP_INTERVAL_MS=300000

# Webhook delivery
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

# Auth (optional - proxy can also trust incoming CF-Access headers)
TRUST_FORWARDED_AUTH=true
